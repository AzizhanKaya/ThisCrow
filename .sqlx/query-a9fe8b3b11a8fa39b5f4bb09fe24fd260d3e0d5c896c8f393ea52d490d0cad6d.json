{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            u.id        AS \"id: id\",\n            u.username,\n            u.name,\n            u.avatar,\n            b.banned_by AS \"banned_by: id\",\n            b.banned_at\n        FROM group_bans b\n        JOIN users u ON u.id = b.user_id\n        WHERE b.group_id = $1\n        ORDER BY b.banned_at DESC\n        ",
