  "query": "\n            SELECT gu.user_id, gu.name, gur.role_id AS \"role_id?\"\n            FROM group_users gu\n            LEFT JOIN group_user_roles gur \n            ON gu.group_id = gur.group_id AND gu.user_id = gur.user_id\n            WHERE gu.group_id = $1\n        ",
